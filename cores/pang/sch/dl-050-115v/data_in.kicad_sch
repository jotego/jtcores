	(text "Line Buffer Even Set"
		(exclude_from_sim no)
		(at 147.32 24.13 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0b7a6b6a-3b23-4ce0-bd5c-12cdeb55018c")
	)
	(text "If HLN is active usually C input is active, except every\nfourth pixel count when D becomes active.\n\nHLN active\n\nH3M4HL	H3M4LH	X\n1		0		C\n1		1		D\n\nLHN active\n\nH3M4HL	H3M4LH	X\n0		1		B\n1		1		D\n"
		(exclude_from_sim no)
		(at 345.44 30.48 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3b27ae76-0796-4e13-975e-2c914a5301f8")
	)
	(text "When \nIn order: D15, D11, D7, D3 -> DI[3:0]\nOut order DO[3:0] -> [D3,D7,D11,D15]"
		(exclude_from_sim no)
		(at 105.41 71.12 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "45c931fc-e5c0-43c0-b997-5a95a5ce913b")
	)
	(text "When buffer has been set to ones, new data\nis enabled.\n\nOBDNW = Odd Buffer Data New "
		(exclude_from_sim no)
		(at 119.38 124.46 0)
		(effects
