CORENAME=JTCAL50

JTFRAME_NOMULTIWAY
JTFRAME_JOY_RLDU
JTFRAME_DIAL
JTFRAME_DIALEMU_LEFT=6

# Video
JTFRAME_COLORW=5
JTFRAME_PXLCLK=8
JTFRAME_WIDTH=376
JTFRAME_HEIGHT=240
JTFRAME_VERTICAL

# MRA
JTFRAME_HEADER=16
JTFRAME_BA1_START=0xA0000
PCM_START=0xE0000
JTFRAME_BA2_START=0x1E0000
JTFRAME_BA3_START=0x3E0000

# Saves NVRAM for release compilations
JTFRAME_IOCTL_RD=4096
# Saves video RAM (not NVRAM) for debug compilations
debug JTFRAME_IOCTL_RD+=12288
debug JTFRAME_IOCTL_RD+=8
debug JTFRAME_IOCTL_RD+=1024
debug JTFRAME_IOCTL_RD+=1024
debug JTFRAME_IOCTL_RD+=8192

[mist|sidi]
# not enough BRAM for M68K RAM
JTFRAME_SKIP