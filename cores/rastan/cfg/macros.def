CORENAME=JTRASTAN

# 6.667MHz pixel clock
JTFRAME_CLK24
JTFRAME_PLL=jtframe_pll6671
JTFRAME_WIDTH=320
JTFRAME_HEIGHT=240

JTFRAME_COLORW=5
JTFRAME_HEADER=16
JTFRAME_LIGHTGUN

JTFRAME_BA1_START=0x60000
PCM_START=0x70000
JTFRAME_BA2_START=0x100000
JTFRAME_BA3_START=0x180000
# C-chip ROMs (Operation Wolf) loaded into module BRAM, not SDRAM.
# Downloaded past the last SDRAM bank (BA3 = pc090oj, 0x180000+0x80000).
# 0x000-0xFFF: 4KB shared mask ROM. 0x1000-0x2FFF: 8KB game EPROM.
JTFRAME_PROM_START=0x200000

JTFRAME_CREDITS_HSTART=32

# debugging
JTFRAME_IOCTL_RD=1024

[mist]
JTFRAME_NOSTA
