CORENAME=JTGRAD3
JTFRAME_MR_DDRLOAD

JTFRAME_JOY_DURL
JTFRAME_BUTTONS=3
JTFRAME_JOY1_POS

# Video configuration. GX945 uses a 24 MHz graphics clock and a 6 MHz
# pixel clock, with a 320x224 visible raster.
JTFRAME_COLORW=8
JTFRAME_PXLCLK=6
JTFRAME_WIDTH=320
JTFRAME_HEIGHT=224

JTFRAME_CREDITS_HSTART=32
JTFRAME_CREDITS_PAGES=1
JTFRAME_IOCTL_RD=4096

# ROM configuration
JTFRAME_HEADER=8
JTFRAME_BA3_WEN
JTFRAME_BA1_START=0x040000
GFX_START=0x140000
JTFRAME_BA2_START=0x340000
PCM_START=0x350000
JTFRAME_PROM_START=0x3D0000
JTFRAME_BA3_START=0x3E0000
JTFRAME_BA3_LEN=64

[sidi|mist]
JTFRAME_SKIP
