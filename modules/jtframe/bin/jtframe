#!/bin/bash -e
POCKET=

if [ -z "$JTFRAME" ]; then
    echo "Missing JTFRAME environment variable definition"
    exit 1
fi

RECOMPILE=FALSE
BIN=$JTFRAME/src/jtframe/jtframe

if [ ! -e $BIN ]; then
    RECOMPILE=TRUE
else
    # Recompile if any source file is newer than the binary
    NEWER=$(find $JTFRAME/src/jtframe -name '*.go' -newer $BIN 2>/dev/null)
    if [ -n "$NEWER" ]; then
        RECOMPILE=TRUE
    fi
fi

function run_tests {
    LOG=`mktemp`
    if ! go test ./... > $LOG; then
        cat $LOG
        rm -f $LOG
        exit 1
    fi
    rm -f $LOG
}

if [ $RECOMPILE = TRUE ]; then
    if [ -e $JTFRAME/target/pocket/pocket.go ]; then
        ln -sf $JTFRAME/target/pocket/pocket.go $JTFRAME/src/jtframe/mra/pocket.go
        POCKET="-tags pocket"
        echo "Compiling jtframe with Pocket support" > /dev/stderr
    fi
    cd $JTFRAME/src/jtframe > /dev/null
    run_tests
    go build $POCKET . || exit $?
    cd - > /dev/null
fi

$BIN $*
