FROM jotego/mame
LABEL maintainer=jotego@gmail.com

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        git \
        jq \
        nodejs \
        npm \
        openssh-client \
        python3 \
        python3-venv \
        make \
        g++ \
        python3-pip \
        ripgrep \
    && rm --recursive --force /var/lib/apt/lists/*

# Install codex in a dedicated virtual environment to avoid system python/package conflicts
RUN python3 -m venv /opt/codex \
    && /opt/codex/bin/pip install --upgrade --no-cache-dir pip \
    && /opt/codex/bin/pip install --no-cache-dir openai-codex \
    || npm install -g @openai/codex

ENV PATH="/opt/codex/bin:${PATH}"

RUN command -v codex >/dev/null 2>&1 || (echo "codex binary not found" && exit 1)

ENTRYPOINT ["bash"]
