FROM jotego/simulator
LABEL maintainer=jotego@gmail.com

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        jq \
        nodejs \
        npm \
        openssh-client \
        python3-pip \
        ripgrep \
    && rm --recursive --force /var/lib/apt/lists/*

# MAME compilation dependencies
RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
        libsdl2-dev \
        libsdl2-ttf-dev \
        libfontconfig-dev \
        libpulse-dev \
        qtbase5-dev \
        qtbase5-dev-tools \
        qtchooser \
        qt5-qmake \
    && rm --recursive --force /var/lib/apt/lists/*

# Keep user-installed python tools on PATH
ENV PATH="/root/.local/bin:${PATH}"

RUN python3 -m pip install --upgrade --no-cache-dir pip \
    || true

RUN python3 -m pip install --no-cache-dir --user openai-codex \
    || npm install -g @openai/codex

RUN command -v codex >/dev/null 2>&1 || (echo "codex binary not found" && exit 1)

ENTRYPOINT ["bash"]
